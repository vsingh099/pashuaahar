# ─────────────────────────────────────────────────────────
# PashuFeed Pro — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────

# ── Supabase (required for npm start / npm run dev) ──────
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Server ────────────────────────────────────────────────
PORT=3000


# ── Local SQLite mode only (npm run local) ────────────────
# JWT_SECRET=change-this-to-a-long-random-secret
# LOCAL_DB_PATH=./local.db

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password

# Owner notification emails (comma-separated)
OWNER_EMAIL=owner1@gmail.com,owner2@gmail.com

# Owner signup protection
OWNER_SIGNUP_CODE=YOUR_SECRET_CODE

# Server
PORT=3000
